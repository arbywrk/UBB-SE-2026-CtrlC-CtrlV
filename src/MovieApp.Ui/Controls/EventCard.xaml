<UserControl
    x:Class="MovieApp.Ui.Controls.EventCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border
        Width="284"
        Padding="0"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="8">
        <Grid RowSpacing="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="156" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                CornerRadius="8,8,0,0">
                <Grid>
                    <Grid Padding="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border
                            HorizontalAlignment="Left"
                            Padding="10,4"
                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Text="{x:Bind EventTypeText, Mode=OneWay}" />
                        </Border>

                        <TextBlock
                            Grid.Row="2"
                            FontSize="28"
                            FontWeight="SemiBold"
                            Text="{x:Bind DateBadgeDay, Mode=OneWay}" />
                    </Grid>
                </Grid>
            </Border>

            <StackPanel
                Grid.Row="1"
                Padding="16"
                Spacing="12">
                <StackPanel Spacing="8">
                    <TextBlock
                        Style="{ThemeResource SubtitleTextBlockStyle}"
                        Text="{x:Bind TitleText, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="WrapWholeWords" />

                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        MaxLines="2"
                        Text="{x:Bind DescriptionText, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE787;" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ScheduleText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE707;" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind LocationText, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </StackPanel>

                    <Border
                        Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Padding="10,6"
                        Background="{x:Bind StatusBackgroundBrush, Mode=OneWay}"
                        CornerRadius="999">
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Text="{x:Bind StatusText, Mode=OneWay}" />
                    </Border>
                </Grid>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="2">
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="Price" />
                        <TextBlock
                            FontWeight="SemiBold"
                            Text="{x:Bind PriceText, Mode=OneWay}" />
                    </StackPanel>
                    
                    <Button Margin="0,15,0,0"
                            HorizontalAlignment="Stretch"
                            Click="VisualSeatGuide_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE7FC;" FontSize="14"/>
                            <TextBlock Text="Visual Seat Guide" />
                        </StackPanel>
                    </Button>

                    <StackPanel
                        Grid.Column="1"
                        Spacing="2">
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="Rating" />
                        <TextBlock
                            FontWeight="SemiBold"
                            Text="{x:Bind RatingText, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel
                        Grid.Column="2"
                        Spacing="2">
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="Capacity" />
                        <TextBlock
                            FontWeight="SemiBold"
                            Text="{x:Bind CapacityText, Mode=OneWay}" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
