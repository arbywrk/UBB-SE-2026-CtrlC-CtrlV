<Page
    x:Class="MovieApp.Ui.Views.DetailsCheckoutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer
        Padding="32"
        VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="24">
            <StackPanel Spacing="6">
                <TextBlock
                    Style="{ThemeResource TitleTextBlockStyle}"
                    Text="Details and Checkout" />
                <TextBlock
                    Style="{StaticResource SectionCaptionTextStyle}"
                    Text="This page is the implementation surface for event details, join or purchase actions, rewards, referral-code entry, and the best-seat guide." />
            </StackPanel>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.6*" />
                    <ColumnDefinition Width="1.1*" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="16">
                    <Border Style="{StaticResource SurfaceCardStyle}">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Height="320"
                                Background="{StaticResource ShellHeroBrush}"
                                CornerRadius="8" />

                            <StackPanel
                                Grid.Column="1"
                                Spacing="12">
                                <TextBlock
                                    Style="{ThemeResource TitleTextBlockStyle}"
                                    Text="Selected event detail host" />
                                <TextBlock
                                    Style="{StaticResource SectionCaptionTextStyle}"
                                    Text="Bind title, description, historical rating, date, location, poster, and seat-availability summary here." />
                                <TextBox Header="Title" Text="Bind event title" />
                                <TextBox Header="Location" Text="Bind event location and hall" />
                                <TextBox Header="Date and time" Text="Bind date/time" />
                                <TextBox Header="Historical rating" Text="Bind normalized rating" />
                                <TextBox
                                    AcceptsReturn="True"
                                    Header="Description"
                                    Height="110"
                                    Text="Bind event description and movie-screening metadata here." />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button Content="Will attend" />
                                    <Button Content="Buy ticket" />
                                    <ToggleButton Content="Favorite" />
                                    <ToggleButton Content="Watch price" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SurfaceCardStyle}">
                        <StackPanel Spacing="16">
                            <TextBlock
                                Style="{ThemeResource SubtitleTextBlockStyle}"
                                Text="Visual seat guide mount" />
                            <TextBlock
                                Style="{StaticResource SectionCaptionTextStyle}"
                                Text="The actual modal should be opened from the event summary area. This preview reserves the seat-map composition and state legend." />
                            <Button HorizontalAlignment="Left" Content="Visual seat guide" />
                            <Border
                                Padding="20"
                                Background="#FFEFE6D5"
                                CornerRadius="8">
                                <StackPanel Spacing="14">
                                    <Border
                                        Padding="8"
                                        Background="#FF233645"
                                        CornerRadius="8">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            Foreground="White"
                                            Text="Screen" />
                                    </Border>
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                                            <Border Width="26" Height="26" Background="#FF8FC2A1" CornerRadius="8" />
                                            <Border Width="26" Height="26" Background="#FFE2B36A" CornerRadius="8" />
                                            <Border Width="26" Height="26" Background="#FFD06A73" CornerRadius="8" />
                                            <Border Width="26" Height="26" Background="#FF8FC2A1" CornerRadius="8" />
                                            <Border Width="26" Height="26" Background="#FF8FC2A1" CornerRadius="8" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                                            <Border Width="26" Height="26" Background="#FF8FC2A1" CornerRadius="8" />
                                            <Border Width="26" Height="26" Background="#FF8FC2A1" CornerRadius="8" />
                                            <Border Width="26" Height="26" Background="#FFE2B36A" CornerRadius="8" />
                                            <Border Width="26" Height="26" Background="#FFE2B36A" CornerRadius="8" />
                                            <Border Width="26" Height="26" Background="#FF8FC2A1" CornerRadius="8" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                                            <Border Width="26" Height="26" Background="#FFD06A73" CornerRadius="8" />
                                            <Border Width="26" Height="26" Background="#FFE2B36A" CornerRadius="8" />
                                            <Border Width="26" Height="26" Background="#FF8FC2A1" CornerRadius="8" />
                                            <Border Width="26" Height="26" Background="#FF8FC2A1" CornerRadius="8" />
                                            <Border Width="26" Height="26" Background="#FF8FC2A1" CornerRadius="8" />
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock
                                        Style="{StaticResource SectionCaptionTextStyle}"
                                        Text="Green, amber, and red seats are placeholders for quality and availability state. Add the Sweet Spot marker in this map layer." />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    Spacing="16">
                    <Border Style="{StaticResource SurfaceCardStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock
                                Style="{ThemeResource SubtitleTextBlockStyle}"
                                Text="Checkout mount" />
                            <TextBlock
                                Style="{StaticResource SectionCaptionTextStyle}"
                                Text="Use this column for paid-event checkout, free enrollment, duplicate-join protection, and final-price calculation." />
                            <TextBox Header="Ticket price" Text="49.99" />
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                                <TextBox x:Name="ReferralCodeTextBox" Header="Referral code" PlaceholderText="Optional code" Width="200" />
                                <Button x:Name="ValidateReferralCodeButton" Click="ValidateReferralCodeButton_Click" VerticalAlignment="Bottom" Height="32">
                                    <FontIcon Glyph="&#xE73E;" FontSize="14" />
                                </Button>
                            </StackPanel>
                            <CheckBox Content="Apply free-enrollment reward" />
                            <CheckBox Content="Apply trivia free ticket reward" />
                            <CheckBox Content="Apply slot-machine movie discount" />
                            <Button Content="Recalculate total" />
                            <TextBox Header="Final price" Text="Never below 0.00" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StrongSurfaceCardStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock
                                Style="{ThemeResource SubtitleTextBlockStyle}"
                                Text="Participation guardrails" />
                            <TextBlock
                                Style="{StaticResource SectionCaptionTextStyle}"
                                Text="Record participation after successful join or purchase and block duplicate participation for the same event from this state owner." />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
