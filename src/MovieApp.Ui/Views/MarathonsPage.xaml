<Page
    x:Class="MovieApp.Ui.Views.MarathonsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="20">
        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.25*" />
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource SurfaceCardStyle}">
                <ListView Height="460" />
            </Border>

            <Border
                Grid.Column="1"
                Style="{StaticResource SurfaceCardStyle}">
                <StackPanel Spacing="10">
                    <TextBox Header="Movie" />
                    <Button Content="Question 1" />
                    <Button Content="Question 2" />
                    <Button Content="Question 3" />
                    <Button Content="Submit" />
                </StackPanel>
            </Border>

            <Border
                Grid.Column="2"
                Style="{StaticResource SurfaceCardStyle}">
                <ListView Height="460" />
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
