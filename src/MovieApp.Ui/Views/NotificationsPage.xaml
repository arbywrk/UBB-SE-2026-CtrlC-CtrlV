<Page
    x:Class="MovieApp.Ui.Views.NotificationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MovieApp.Core.Models"
    mc:Ignorable="d">

    <ScrollViewer Padding="20">
        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.6*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource SurfaceCardStyle}">
                <ListView
                    Height="480"
                    ItemsSource="{x:Bind ViewModel.Notifications, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedNotification, Mode=TwoWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:Notification">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind Type}" />
                                <TextBlock Text="{x:Bind Message}" TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <Border
                Grid.Column="1"
                Style="{StaticResource SurfaceCardStyle}">
                <StackPanel Spacing="10">
                    <TextBox Header="Type" IsReadOnly="True" Text="{x:Bind ViewModel.SelectedNotification.Type, Mode=OneWay}" />
                    <TextBox Header="Event" IsReadOnly="True" Text="{x:Bind ViewModel.SelectedNotification.EventId, Mode=OneWay}" />
                    <TextBox
                        AcceptsReturn="True"
                        Header="Message"
                        Height="220"
                        IsReadOnly="True"
                        Text="{x:Bind ViewModel.SelectedNotification.Message, Mode=OneWay}" />
                    <Button Command="{x:Bind ViewModel.MarkAsReadCommand}" Content="Mark as read / Remove" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
