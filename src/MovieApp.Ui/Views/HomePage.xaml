<Page
    x:Class="MovieApp.Ui.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:MovieApp.Ui.Controls"
    mc:Ignorable="d">

    <ScrollViewer Padding="24" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="24">
            <TextBlock
                Style="{ThemeResource HeaderTextBlockStyle}"
                Text="{Binding PageTitle}" />

            <AutoSuggestBox
                Width="320"
                PlaceholderText="Search events"
                TextChanged="SearchBox_TextChanged" />

            <ItemsControl ItemsSource="{Binding Sections}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Spacing="8">
                            <Button
                                Padding="0"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="SectionHeaderButton_Click">
                                <ui:SectionHeader
                                    Title="{Binding Title}"
                                    ActionText="See all" />
                            </Button>

                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding Events}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="12" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="EventCardButton_Click">
                                                <ui:EventCard Model="{Binding}" />
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>