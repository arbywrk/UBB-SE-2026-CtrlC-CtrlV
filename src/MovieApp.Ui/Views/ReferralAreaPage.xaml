<Page
    x:Class="MovieApp.Ui.Views.ReferralAreaPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MovieApp.Core.Models"
    mc:Ignorable="d">

    <ScrollViewer Padding="20">
        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource SurfaceCardStyle}">
                <StackPanel Spacing="12">
                    <TextBox Header="Referral code" Text="{x:Bind ReferralCode, Mode=OneWay}" IsReadOnly="True" />
                    <ListView Height="400" ItemsSource="{x:Bind ReferralHistory, Mode=OneWay}" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:ReferralHistoryItem">
                                <StackPanel Margin="0,8">
                                    <TextBlock Text="{x:Bind FriendName}" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind EventTitle}" Style="{StaticResource CaptionTextBlockStyle}" />
                                    <TextBlock Text="{x:Bind FormattedDate}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="Gray" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <Border
                Grid.Column="1"
                Style="{StaticResource SurfaceCardStyle}">
                <StackPanel Spacing="10">
                    <TextBox Header="Entered code" />
                    <TextBox Header="Event" />
                    <CheckBox Content="Reject self-referral" IsChecked="True" />
                    <Button Content="Validate" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
