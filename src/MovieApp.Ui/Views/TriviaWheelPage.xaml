<Page
    x:Class="MovieApp.Ui.Views.TriviaWheelPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="20" VerticalScrollBarVisibility="Auto">
        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.3*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  LEFT PANEL — Wheel  -->
            <Border Style="{StaticResource SurfaceCardStyle}">
                <StackPanel Spacing="16" HorizontalAlignment="Center">

                    <TextBlock
                        Style="{ThemeResource TitleTextBlockStyle}"
                        Text="Movie Trivia Wheel"
                        HorizontalAlignment="Center" />

                    <TextBlock
                        x:Name="RemainingSpinsText"
                        HorizontalAlignment="Center"
                        Style="{StaticResource SectionCaptionTextStyle}" />

                    <!--  Countdown — only visible when spin is blocked  -->
                    <Border
                        x:Name="CountdownBanner"
                        Visibility="Collapsed"
                        Style="{StaticResource StrongSurfaceCardStyle}"
                        Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <TextBlock
                                    Text="⏳ Next spin available in:"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource SectionCaptionTextStyle}" />
                            <TextBlock
                        x:Name="CountdownText"
                        FontWeight="Bold"
                        FontSize="14"
                        VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <TextBlock
                        Text="▼"
                        FontSize="24"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />

                    <Canvas
                        x:Name="WheelCanvas"
                        Width="280"
                        Height="280"
                        HorizontalAlignment="Center">
                        <Canvas.RenderTransform>
                            <RotateTransform
                                x:Name="WheelRotation"
                                CenterX="140"
                                CenterY="140" />
                        </Canvas.RenderTransform>
                    </Canvas>

                    <!--  Selected category label  -->
                    <TextBlock
                        x:Name="SelectedCategoryText"
                        HorizontalAlignment="Center"
                        FontWeight="Bold"
                        FontSize="20" />

                    <Button
                        x:Name="SpinButton"
                        Content="Spin the Wheel"
                        HorizontalAlignment="Center"
                        Click="SpinButton_Click" />

                    <TextBlock
                        x:Name="TriviaAvailabilityText"
                        MaxWidth="320"
                        HorizontalAlignment="Center"
                        Opacity="0.8"
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords"
                        Visibility="Collapsed"
                        Style="{StaticResource SectionCaptionTextStyle}" />

                    <Border Style="{StaticResource StrongSurfaceCardStyle}" Padding="12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="How to win" FontWeight="SemiBold" />
                            <TextBlock
                                Text="Answer all 20 questions correctly to earn a free event ticket reward. One spin per day."
                                TextWrapping="WrapWholeWords"
                                Style="{StaticResource SectionCaptionTextStyle}" />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

            <!--  RIGHT PANEL  -->
            <Border Grid.Column="1" Style="{StaticResource SurfaceCardStyle}">
                <Grid>

                    <!--  STATE 1: Idle  -->
                    <StackPanel
                        x:Name="IdlePanel"
                        Spacing="12"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                        <TextBlock
                            x:Name="IdleTitleText"
                            Text="Spin the wheel to begin!"
                            Style="{ThemeResource TitleTextBlockStyle}"
                            HorizontalAlignment="Center" />
                        <TextBlock
                            x:Name="IdleDescriptionText"
                            Text="A category will be selected and you'll answer 20 trivia questions."
                            TextWrapping="WrapWholeWords"
                            HorizontalAlignment="Center"
                            Style="{StaticResource SectionCaptionTextStyle}" />
                    </StackPanel>

                    <!--  STATE 2: Playing  -->
                    <StackPanel
                        x:Name="PlayingPanel"
                        Spacing="12"
                        Visibility="Collapsed">

                        <StackPanel Spacing="4">
                            <TextBlock x:Name="ProgressText" />
                            <ProgressBar
                                x:Name="ProgressBar"
                                Minimum="0"
                                Maximum="100" />
                        </StackPanel>

                        <TextBlock
                            x:Name="QuestionText"
                            TextWrapping="WrapWholeWords"
                            FontWeight="SemiBold"
                            FontSize="16" />

                        <RadioButton x:Name="OptionA" GroupName="Answers" />
                        <RadioButton x:Name="OptionB" GroupName="Answers" />
                        <RadioButton x:Name="OptionC" GroupName="Answers" />
                        <RadioButton x:Name="OptionD" GroupName="Answers" />

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button
                                x:Name="HintButton"
                                Content="Use Hint"
                                Click="HintButton_Click" />
                            <Button
                                Content="Submit Answer"
                                Click="SubmitAnswer_Click" />
                        </StackPanel>

                    </StackPanel>

                    <!--  STATE 3: Results  -->
                    <StackPanel
                    x:Name="ResultsPanel"
                    Spacing="20"
                    Visibility="Collapsed"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">

                        <TextBlock
                            x:Name="ResultsTitleText"
                            Style="{ThemeResource TitleTextBlockStyle}"
                            FontSize="32"
                            FontWeight="Bold"
                            HorizontalAlignment="Center" />

                        <!--  Large scoreboard number  -->
                        <TextBlock
                            x:Name="ResultsScoreText"
                            FontSize="72"
                            FontWeight="Bold"
                            HorizontalAlignment="Center" />

                        <TextBlock
                            Text="out of 20"
                            FontSize="18"
                            HorizontalAlignment="Center"
                            Opacity="0.6" />

                        <TextBlock
                            x:Name="ResultsRewardText"
                            FontSize="16"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Center"
                            TextWrapping="WrapWholeWords"
                            TextAlignment="Center" />

                    </StackPanel>

                </Grid>
            </Border>

        </Grid>
    </ScrollViewer>
</Page>
