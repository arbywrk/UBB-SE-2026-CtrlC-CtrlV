<Page
    x:Class="MovieApp.Ui.Views.FavoritesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MovieApp.Core.Models"
    mc:Ignorable="d">

    <ScrollViewer
        Padding="32"
        VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="24">
            <StackPanel Spacing="6">
                <TextBlock
                    Style="{ThemeResource TitleTextBlockStyle}"
                    Text="Favorites" />
                <TextBlock
                    Style="{StaticResource SectionCaptionTextStyle}"
                    Text="Manage your favorited events here." />
            </StackPanel>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock
                            Style="{ThemeResource SubtitleTextBlockStyle}"
                            Text="Favorite-event list" />
                        <ListView
                            Height="420"
                            ItemsSource="{x:Bind ViewModel.Favorites, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedFavorite, Mode=TwoWay}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:Event">
                                    <TextBlock Text="{x:Bind Title}" />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <StackPanel
                    Grid.Column="1"
                    Spacing="16">
                    <Border Style="{StaticResource SurfaceCardStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock
                                Style="{ThemeResource SubtitleTextBlockStyle}"
                                Text="Selected favorite detail" />
                            <TextBox Header="Selected title" IsReadOnly="True" Text="{x:Bind ViewModel.SelectedFavorite.Title, Mode=OneWay}" />
                            <TextBox Header="Current price" IsReadOnly="True" Text="{x:Bind ViewModel.SelectedFavorite.TicketPrice, Mode=OneWay}" />
                            <TextBox Header="Seat availability" IsReadOnly="True" Text="{x:Bind ViewModel.SelectedFavorite.AvailableSpots, Mode=OneWay}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Command="{x:Bind ViewModel.RemoveFavoriteCommand}" Content="Remove favorite" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
