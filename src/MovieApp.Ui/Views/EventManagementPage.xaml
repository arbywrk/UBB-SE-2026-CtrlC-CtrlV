<Page
    x:Class="MovieApp.Ui.Views.EventManagementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:ui="using:MovieApp.Ui.Controls"
    mc:Ignorable="d">

    <ScrollViewer Padding="32" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="24">

            <TextBlock Style="{ThemeResource TitleTextBlockStyle}" Text="{Binding PageTitle}" />

            <Border Style="{StaticResource SurfaceCardStyle}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:EventSearchBox
                        PlaceholderText="Search events by title or type"
                        SearchTextChanged="SearchBox_SearchTextChanged" />
                    <ui:EventSortSelector
                        Grid.Column="1"
                        PlaceholderText="Sort events"
                        SelectedSortOption="{Binding EventListState.SelectedSortOption, Mode=OneWay}"
                        SortOptionChanged="SortSelector_SortOptionChanged" />
                    <ComboBox Grid.Column="2" PlaceholderText="Filter">
                        <x:String>Location</x:String>
                        <x:String>Type</x:String>
                        <x:String>Minimum rating</x:String>
                    </ComboBox>
                    <Button Grid.Column="3" Content="Clear" />
                </Grid>
            </Border>

            <ListView
                x:Name="EventListView"
                Height="250"
                ItemsSource="{Binding VisibleEvents}"
                SelectedItem="{x:Bind ViewModel.SelectedEvent, Mode=TwoWay}"
                SelectionChanged="EventListView_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="64" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Id}" />
                            <TextBlock Grid.Column="1" Text="{Binding Title}" />
                            <TextBlock Grid.Column="2" Text="{Binding EventDateTime}" />
                            <TextBlock Grid.Column="3" Text="{Binding LocationReference}" />
                            <TextBlock Grid.Column="4" Text="{Binding TicketPrice}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,-12,0,0">
                <StackPanel Spacing="16">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Create or edit event" />
                    <Grid ColumnSpacing="16" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBox Header="Title" PlaceholderText="Event title" Text="{x:Bind ViewModel.FormTitle, Mode=TwoWay}" />
                        <TextBox Grid.Column="1" Header="Location" PlaceholderText="Venue and hall" Text="{x:Bind ViewModel.FormLocation, Mode=TwoWay}" />
                        <ComboBox Grid.Column="2" Header="Event type" PlaceholderText="Choose type">
                            <x:String>Premiere</x:String>
                            <x:String>Marathon</x:String>
                            <x:String>Outdoor screening</x:String>
                        </ComboBox>

                        <CalendarDatePicker Grid.Row="1" Header="Date" Date="{x:Bind ViewModel.FormDate, Mode=TwoWay}" />
                        <TimePicker Grid.Row="1" Grid.Column="1" Header="Time" Time="{x:Bind ViewModel.FormTime, Mode=TwoWay}" />
                        <controls:NumberBox Grid.Row="1" Grid.Column="2" Header="Ticket price" PlaceholderText="0.00" Value="{x:Bind ViewModel.FormPrice, Mode=TwoWay}" />

                        <TextBox
                            Grid.Row="2"
                            Grid.ColumnSpan="2"
                            AcceptsReturn="True"
                            Header="Description"
                            Height="120"
                            TextWrapping="Wrap"
                            Text="{x:Bind ViewModel.FormDescription, Mode=TwoWay}" />
                        <StackPanel Grid.Row="2" Grid.Column="2" Spacing="10">
                            <controls:NumberBox Header="Capacity" PlaceholderText="150" Value="{x:Bind ViewModel.FormCapacity, Mode=TwoWay}" />
                            <TextBox Header="Poster path" PlaceholderText="assets/posters/..." Text="{x:Bind ViewModel.FormPosterUrl, Mode=TwoWay}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock
                        Text="{x:Bind ViewModel.ValidationMessage, Mode=OneWay}"
                        Foreground="{ThemeResource SystemErrorTextColor}" />

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Create" Command="{x:Bind ViewModel.CreateEventCommand}" />
                        <Button Content="Edit selected" Command="{x:Bind ViewModel.EditEventCommand}" />
                        <Button Content="Delete selected" Command="{x:Bind ViewModel.DeleteEventCommand}" />
                        <Button Content="Simulate Update" Click="SimulateUpdate_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>