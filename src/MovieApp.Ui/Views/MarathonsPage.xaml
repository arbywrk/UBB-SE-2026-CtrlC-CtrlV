<Page
    x:Class="MovieApp.Ui.Views.MarathonsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:MovieApp.Core.Models"
    mc:Ignorable="d">

    <ScrollViewer Padding="20">
        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.25*" />
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: Marathon list + progress -->
            <Border Style="{StaticResource SurfaceCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}"
                               Text="This week's marathons" />
                    <ListView x:Name="MarathonListView"
                              ItemsSource="{x:Bind ViewModel.Marathons, Mode=OneWay}"
                              SelectionChanged="MarathonListView_SelectionChanged"
                              Height="380">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:Marathon">
                                <StackPanel Padding="4" Spacing="2">
                                    <TextBlock Text="{x:Bind Title}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind Theme}"
                                               FontSize="12" Opacity="0.6" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <Border Style="{StaticResource StrongSurfaceCardStyle}">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Your progress"
                                       FontWeight="SemiBold" />
                            <TextBlock
                                Text="{x:Bind ViewModel.ProgressText, Mode=OneWay}"
                                Style="{StaticResource SectionCaptionTextStyle}" />
                            <TextBlock x:Name="LockedBanner"
                                       Text="Locked — complete the prerequisite marathon first"
                                       Foreground="{ThemeResource SystemErrorTextColor}"
                                       Visibility="Collapsed" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Middle: Quiz area -->
            <Border Grid.Column="1" Style="{StaticResource SurfaceCardStyle}">
                <StackPanel Spacing="12">

                    <!-- Idle state -->
                    <StackPanel x:Name="IdlePanel" Spacing="8">
                        <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}"
                                   Text="Select a marathon" />
                        <TextBlock Style="{StaticResource SectionCaptionTextStyle}"
                                   Text="Choose a marathon on the left, then click Log on a movie to start the trivia check." />
                    </StackPanel>

                    <!-- Playing state -->
                    <StackPanel x:Name="PlayingPanel"
                                Visibility="Collapsed" Spacing="10">
                        <TextBlock x:Name="QuizMovieTitle"
                                   FontWeight="SemiBold" FontSize="16" />
                        <TextBlock x:Name="QuizProgress"
                                   Style="{StaticResource SectionCaptionTextStyle}" />
                        <TextBlock x:Name="QuizQuestion"
                                   TextWrapping="WrapWholeWords"
                                   FontWeight="SemiBold" />
                        <RadioButton x:Name="OptionA" GroupName="Quiz" />
                        <RadioButton x:Name="OptionB" GroupName="Quiz" />
                        <RadioButton x:Name="OptionC" GroupName="Quiz" />
                        <RadioButton x:Name="OptionD" GroupName="Quiz" />
                        <Button x:Name="SubmitButton"
                                Content="Submit answer"
                                IsEnabled="False"
                                Click="SubmitButton_Click" />
                    </StackPanel>

                    <!-- Result state -->
                    <StackPanel x:Name="ResultPanel"
                                Visibility="Collapsed" Spacing="10">
                        <TextBlock x:Name="ResultText"
                                   FontWeight="SemiBold" FontSize="16"
                                   TextWrapping="WrapWholeWords" />
                        <Button x:Name="TryAgainButton"
                                Content="Try again"
                                Visibility="Collapsed"
                                Click="TryAgainButton_Click" />
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- Right: Leaderboard -->
            <Border Grid.Column="2" Style="{StaticResource SurfaceCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}"
                               Text="Leaderboard" />
                    <ListView x:Name="LeaderboardListView"
                              ItemsSource="{x:Bind ViewModel.Leaderboard, Mode=OneWay}"
                              Height="440">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:MarathonProgress">
                                <StackPanel Padding="4" Spacing="2">
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{x:Bind CompletedMoviesCount}" />
                                    <TextBlock FontSize="12" Opacity="0.7"
                                               Text="{x:Bind TriviaAccuracy}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>