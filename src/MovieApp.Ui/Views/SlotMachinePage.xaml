<Page
    x:Class="MovieApp.Ui.Views.SlotMachinePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:MovieApp.Ui.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <local:NegativeBooleanConverter x:Key="NegativeBooleanConverter" />
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <local:BoolToHighlightBrushConverter x:Key="BoolToHighlightBrushConverter" />
    </Page.Resources>

    <ScrollViewer Padding="20">
        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.6*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="16">
                <!-- Slot Machine Reels Display -->
                <Border Style="{StaticResource SurfaceCardStyle}" Padding="12">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Genre Reel -->
                        <Border Grid.Column="0" Style="{StaticResource StrongSurfaceCardStyle}" MinHeight="200" Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="GENRE" HorizontalAlignment="Center" FontSize="14" FontWeight="Bold" Opacity="0.7" Margin="0,0,0,8" />
                                <TextBlock Grid.Row="1" Text="{Binding SelectedGenre.Name}" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" />
                                <ProgressRing Grid.Row="2" IsActive="{Binding IsGenreSpinning}" Width="24" Height="24" HorizontalAlignment="Center" Margin="0,8,0,0" />
                            </Grid>
                        </Border>

                        <!-- Actor Reel -->
                        <Border Grid.Column="1" Style="{StaticResource StrongSurfaceCardStyle}" MinHeight="200" Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="ACTOR" HorizontalAlignment="Center" FontSize="14" FontWeight="Bold" Opacity="0.7" Margin="0,0,0,8" />
                                <TextBlock Grid.Row="1" Text="{Binding SelectedActor.Name}" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" />
                                <ProgressRing Grid.Row="2" IsActive="{Binding IsActorSpinning}" Width="24" Height="24" HorizontalAlignment="Center" Margin="0,8,0,0" />
                            </Grid>
                        </Border>

                        <!-- Director Reel -->
                        <Border Grid.Column="2" Style="{StaticResource StrongSurfaceCardStyle}" MinHeight="200" Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="DIRECTOR" HorizontalAlignment="Center" FontSize="14" FontWeight="Bold" Opacity="0.7" Margin="0,0,0,8" />
                                <TextBlock Grid.Row="1" Text="{Binding SelectedDirector.Name}" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" />
                                <ProgressRing Grid.Row="2" IsActive="{Binding IsDirectorSpinning}" Width="24" Height="24" HorizontalAlignment="Center" Margin="0,8,0,0" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Matching Events -->
                <Border Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Matching Events" FontSize="16" FontWeight="SemiBold" />
                        <ListView ItemsSource="{Binding MatchingEvents}" Height="220">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding IsJackpotEvent, Converter={StaticResource BoolToHighlightBrushConverter}}"
                                            CornerRadius="4" Padding="8">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Spacing="4">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding Event.Title}" FontWeight="Bold" />
                                                    <TextBlock Text="⭐ JACKPOT" FontWeight="Bold" Foreground="#D4A017"
                                                               Visibility="{Binding IsJackpotEvent, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Event.EventDateTime}" FontSize="12" Opacity="0.7" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding PriceText}" VerticalAlignment="Center" FontWeight="Bold" />
                                            <Button Grid.Column="2" Content="View Event" Click="ViewEventButton_Click"
                                                    VerticalAlignment="Center" Padding="8,4" FontSize="12" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Control Panel -->
            <Border Grid.Column="1" Style="{StaticResource SurfaceCardStyle}" VerticalAlignment="Top">
                <StackPanel Spacing="16" Padding="4">
                    <!-- Spin Stats -->
                    <StackPanel Spacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Daily Spins" FontSize="12" Opacity="0.7" />
                            <TextBlock Text="{Binding AvailableSpins}" FontSize="24" FontWeight="Bold" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Bonus Spins" FontSize="12" Opacity="0.7" />
                            <TextBlock Text="{Binding BonusSpins}" FontSize="24" FontWeight="Bold" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Login Streak" FontSize="12" Opacity="0.7" />
                            <TextBlock Text="{Binding LoginStreak}" FontSize="24" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>

                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8" />

                    <!-- Status Message -->
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" FontSize="13" Opacity="0.9" />

                    <!-- Spin Button -->
                    <Button 
                        Content="SPIN" 
                        Command="{Binding SpinCommand}"
                        IsEnabled="{Binding IsSpinButtonEnabled}"
                        HorizontalAlignment="Stretch"
                        Padding="12,16"
                        FontSize="16"
                        FontWeight="Bold" />

                    <!-- Loading Indicator -->
                    <ProgressRing IsActive="{Binding IsSpinning}" Visibility="{Binding IsSpinning}" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>

