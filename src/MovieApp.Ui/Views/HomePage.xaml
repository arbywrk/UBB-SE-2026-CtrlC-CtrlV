<Page
    x:Class="MovieApp.Ui.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:MovieApp.Ui.Controls"
    mc:Ignorable="d">

    <ScrollViewer Padding="24" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16">
            <TextBlock
                Style="{ThemeResource HeaderTextBlockStyle}"
                Text="{Binding PageTitle}" />

            <ui:EventSearchBox
                PlaceholderText="Search events by title or type"
                SearchTextChanged="SearchBox_SearchTextChanged" />

            <ui:EventSortSelector
                PlaceholderText="Sort home events"
                SelectedSortOption="{Binding EventListState.SelectedSortOption, Mode=OneWay}"
                SortOptionChanged="SortSelector_SortOptionChanged" />

            <Border Style="{StaticResource SurfaceCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock
                        Style="{StaticResource SectionTitleTextStyle}"
                        Text="Shortcuts" />

                    <ItemsControl ItemsSource="{Binding NavigationShortcuts}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="12" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button
                                    Padding="16"
                                    Background="Transparent"
                                    Click="ShortcutButton_Click">
                                    <StackPanel
                                        Width="220"
                                        Spacing="6">
                                        <TextBlock
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Text="{Binding Title}" />
                                        <TextBlock
                                            Opacity="0.75"
                                            Text="{Binding Description}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <ItemsControl ItemsSource="{Binding Sections}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Spacing="8">
                            <ui:SectionHeader Title="{Binding Title}" />

                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding Events}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="12" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="EventCardButton_Click">
                                                <ui:EventCard Model="{Binding}" />
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
